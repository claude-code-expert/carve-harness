{
  "name": "carve-harness",
  "version": "1.0.0",
  "description": "범용 하네스 자산을 프로젝트에 맞게 깎아 설치하는 CLI (carve = 깎아서 만들다, a.k.a. 하네스 깎는 노인 코드빌런)",
  "author": "villainscode <villainscode@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/claude-code-expert/carve-harness.git"
  },
  "bugs": {
    "url": "https://github.com/claude-code-expert/carve-harness/issues"
  },
  "homepage": "https://github.com/claude-code-expert/carve-harness#readme",
  "type": "module",
  "bin": {
    "carve": "bin/carve.js"
  },
  "files": [
    "bin/carve.js",
    "src/**/*.js",
    "assets"
  ],
  "engines": {
    "node": ">=22.18"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -f bin/*.js src/*.js",
    "test": "node --test 'test/**/*.test.ts'",
    "test:cov": "node --test --experimental-test-coverage --test-coverage-lines=0.8 --test-coverage-functions=0.8 'test/**/*.test.ts'",
    "prepack": "npm run clean && npm run build",
    "prepublishOnly": "npm run check && npm test"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.10.0"
  },
  "license": "MIT"
}
